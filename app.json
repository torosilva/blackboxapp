{
  "expo": {
    "name": "BLACKBOX",
    "slug": "AiDiaryApp",
    "scheme": "blackbox",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo_square.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#020617"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.blackboxmind.app",
      "config": {
        "usesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.blackboxmind.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo_square.png",
        "backgroundColor": "#020617"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-localization",
      "expo-font",
      "expo-notifications",
      "expo-av",
      "expo-camera",
      "expo-image-picker",
      "expo-local-authentication"
    ],
    "extra": {
      "eas": {
        "projectId": "48e06f1b-3a2d-4187-9e84-c4fd534cd0a4"
      }
    }
  }
}